import time

def chatbot():
    # Rule-based dictionary: {Keyword: Response}
    rules = {
        "hello": "Hi there! How can I help you today?",
        "hi": "Hello! I'm your assistant bot.",
        "how are you": "I'm doing great! Just living in the cloud. How about you?",
        "name": "I am a Rule-Based Chatbot created for Task 5.",
        "python": "Python is my favorite language! It's so readable.",
        "help": "I can answer greetings, tell you my name, or discuss Python!",
        "bye": "Goodbye! It was nice chatting with you."
    }

    print("--- Chatbot Initialized (Type 'bye' to exit) ---")

    while True:
        user_input = input("You: ").lower()

        # Check for exit condition
        if user_input == 'bye' or user_input == 'exit':
            print(f"Chatbot: {rules['bye']}")
            break

        found_match = False
        
        # Search for keywords in the user's message
        for keyword, response in rules.items():
            if keyword in user_input:
                print(f"Chatbot: {response}")
                found_match = True
                break # Stop after the first match to avoid multiple responses
        
        # Default response if no rules are met
        if not found_match:
            print("Chatbot: That sounds interesting, but I'm not sure how to respond to that yet!")

if __name__ == "__main__":
    chatbot()
